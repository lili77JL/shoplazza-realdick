<style>
  [data-section-id="{{ section.id }}"] .products-tabs {
    flex-wrap: nowrap;
    overflow-x: auto;
    padding: 0 16px 12px;
    box-shadow: 0 -1px var(--color-border) inset;
    -webkit-overflow-scrolling: touch;
  }

  [data-section-id="{{ section.id }}"] .products-tabs li {
    padding: 8px 12px;
    white-space: nowrap;
    color: var(--color-general-heading-text);
    border: 3px solid transparent;
    border-radius: 9999px;
    box-sizing: border-box;
    position: relative;
    transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  [data-section-id="{{ section.id }}"] .products-tabs li::after {
    content: '';
    position: absolute;
    bottom: -15px;
    left: 0;
    width: 100%;
    height: 2px;
    background-color: #000;
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }

  [data-section-id="{{ section.id }}"] .products-tabs li + li {
    margin-left: 24px;
  }

  [data-section-id="{{ section.id }}"] .products-tabs li[active] {
    opacity: 1;
    position: relative;
    cursor: pointer;
    background: linear-gradient(to bottom, #ff8ecf, #ffffff);
    border-color: #ffe6f3;
    box-shadow: 0px 2px 10px #ffe6f3;
  }

  [data-section-id="{{ section.id }}"] .products-tabs li[active]::after {
    transform: scaleX(1);
  }

  [data-section-id="{{ section.id }}"] .products-tab-view-more-icon {
    margin-left: 4px;
  }

  @media (min-width: 960px) {
    [data-section-id="{{ section.id }}"] .products-tabs li {
      line-height: 44px;
      color: var(--color-general-heading-text);
      font-size: calc(var(--type-heading-font-size) * 0.67);
    }

    [data-section-id="{{ section.id }}"] .products-tabs li + li {
      margin-left: 36px;
    }

    [data-section-id="{{ section.id }}"] .products-tabs li[active] {
      font-size: calc(var(--type-heading-font-size) * 0.67);
    }
  }
</style>

{% if shop.locale == "ar-SA" %}
  <style>
    html[dir="rtl"] [data-section-id="{{ section.id }}"] .products-tab-view-more-icon {
      transform: rotate(180deg);
    }

    html[dir="rtl"] [data-section-id="{{ section.id }}"] .products-tabs li + li {
      margin-left: 0;
      margin-right: 24px;
    }

    @media (min-width: 960px) {
      html[dir="rtl"] [data-section-id="{{ section.id }}"] .products-tabs li + li {
        margin-left: 0;
        margin-right: 36px;
      }
    }
  </style>
{% endif %}