{% include 'cart_css' %}
{% include 'cart_countdown_template' %}
<div id="cart-payment-breakdown" class="hidden">
  {% if section.blocks.size == 0 %}
  {%- comment -%} Keep the original logic when no block is added. {%- endcomment -%}
  {% include 'cart_subtotal', isBock: false %}
  {% include 'cart_summary_sticky' %}
  {% else %}
  {% include 'cart_subtotal', isBock: true %}
  {% include 'cart_summary_sticky' %}
  {% endif %}
</div>
{% schema %}
{
  "name": "cart_payment_breakdown",
  "templates": ["cart"],
  "limit": 1,
  "settings": [],
  "updateNeedRefresh": true,
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "payment_detail",
      "limit": 1,
      "name": {
        "en-US": "Payment detail",
        "zh-CN": "金额详情"
      },
      "settings": []
    },
    {
      "type": "checkout_button",
      "limit": 1,
      "name": {
        "en-US": "Checkout button",
        "zh-CN": "结算按钮"
      },
      "settings": []
    },
    {
      "type": "cart_ec_button",
      "limit": 1,
      "name": {
        "en-US": "Express checkout button",
        "zh-CN": "快捷结账按钮"
      },
      "settings": [],
      "info": {
        "zh-CN": "启用动态快捷结账按钮后，系统将运用智能算法，为当前顾客推荐最为适配的快捷支付方式。若需使用该功能，请先确保已在支付服务商处开通上述支付方式的快捷支付功能。",
        "en-US": "When the dynamic express checkout button is enabled, the system will use intelligent algorithms to recommend the most suitable express payment method for the current customer. To use this feature, please ensure that express checkout has been enabled for the above payment methods with your payment service provider."
      }
    }
  ],
  "presets": [
    {
      "name":"cart_payment_breakdown",
      "cname": {
        "zh-CN": "总计",
        "en-US": "Payment breakdown"
      },
      "category": {
        "en-US": "Page",
        "zh-CN": "页面"
      },
      "ccategory": {
        "en-US": "Page",
        "zh-CN": "页面"
      },
      "display": true,
      "blocks": [
        {
          "type": "payment_detail",
          "settings": {}
        },
        {
          "type": "checkout_button",
          "settings": {}
        },
        {
          "type": "cart_ec_button",
          "settings": {}
        }
      ]
    }
  ]
}
{% endschema %}