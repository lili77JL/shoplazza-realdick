    {
      "type": "spacing",
      "id": "spacing",
      "label": {
        "en-US": "Spacing",
        "zh-CN": "间距留白"
      },
      "pc": {
        "top": "40",
        "right": "",
        "bottom": "40",
        "left": ""
      },
      "mobile": {
        "top": "20",
        "right": "",
        "bottom": "20",
        "left": ""
      },
      "default": {
        "pc": {
          "top": "40",
          "right": "",
          "bottom": "40",
          "left": ""
        },
        "mobile": {
          "top": "20",
          "right": "",
          "bottom": "20",
          "left": ""
        }
      }
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": {
        "en-US": "Card",
        "zh-CN": "卡片"
      },
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": {
            "en-US": "Collection",
            "zh-CN": "专辑链接"
          }
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": {
            "en-US": "Image",
            "zh-CN": "图片"
          }
        },
        {
          "type": "text",
          "id": "title",
          "label": {
            "en-US": "Card title",
            "zh-CN": "卡片标题"
          },
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "collection_list_sim",
      "cname": {
        "en-US": "Collection list simple",
        "zh-CN": "Collection list simple"
      },
      "category": {
        "en-US": "Collection",
        "zh-CN": "专辑"
      },
      "ccategory": {
        "en-US": "Collection",
        "zh-CN": "专辑"
      },
      "display": true,
      "blocks": [
        {
          "type": "card",
          "settings": {
            "collection": {},
            "title": ""
          }
        },
        {
          "type": "card",
          "settings": {
            "collection": {},
            "title": ""
          }
        },
        {
          "type": "card",
          "settings": {
            "collection": {},
            "title": ""
          }
        },
        {
          "type": "card",
          "settings": {
            "collection": {},
            "title": ""
          }
        }
