{% comment %}
File: sections/tag_list.liquid
ElecHub — Tag List (spacing & container aligned to collection_list)
{% endcomment %}

{% include 'card_spacing_css' %}

<style>
  /* 作用域限定到当前 section，避免影响其它模块 */
  [data-section-id="{{ section.id }}"] .taglist__wrap{
    background: {{ section.settings.background }};
  }

  [data-section-id="{{ section.id }}"] .taglist__title{
    /* 保留主题字体，只控制外边距，与 collection_list 标题一致 */
    margin: 0;
  }

  [data-section-id="{{ section.id }}"] .tag-container{
    display:flex; flex-wrap:wrap; gap:12px 15px; align-items:center;
  }

  [data-section-id="{{ section.id }}"] .tag-item{
    color: {{ section.settings.tag_color }};
    background: {{ section.settings.tag_background }};
    padding: 6px 12px;
    border-radius: 999px;
    line-height: 1.2;
    font-size: 14px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    box-shadow: 0 2px 6px rgba(0,0,0,.08);
    transition: transform .15s ease, box-shadow .15s ease, opacity .2s ease;
  }
  [data-section-id="{{ section.id }}"] .tag-item:hover{
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(0,0,0,.12);
    opacity: .95;
  }
</style>

<div class="page-container container lg:container" data-section-id="{{ section.id }}">
  <div class="taglist">
    {% if section.settings.title != blank %}
      <h4 class="taglist__title title-font type-heading-font-family font-normal leading-1.2 overflow-hidden">
        {{ section.settings.title | escape }}
      </h4>
    {% endif %}

    <!-- 与 collection_list 保持：内容区顶边距移动端 pt-2、PC 端 lg:pt-1 -->
    <div class="taglist__wrap pt-2 lg:pt-1">
      <div class="tag-container">
        {% for block in section.blocks %}
          {% assign t = block.settings.tag_name %}
          {% if t != blank %}
            {% if block.settings.link != blank %}
              <a class="tag-item" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ t }}</a>
            {% else %}
              <span class="tag-item" {{ block.shopify_attributes }}>{{ t }}</span>
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "tag_list",
  "templates": ["index", "collection", "product", "page"],
  "settings": [
    { "type": "text",  "id": "title",          "label": { "en-US": "Heading", "zh-CN": "标题" }, "default": "Brands" },
    { "type": "color", "id": "background",     "label": { "en-US": "Background", "zh-CN": "背景色" }, "default": "rgba(0,0,0,0)" },
    { "type": "color", "id": "tag_color",      "label": { "en-US": "Tag text color", "zh-CN": "标签文字颜色" }, "default": "#ffffff" },
    { "type": "color", "id": "tag_background", "label": { "en-US": "Tag background", "zh-CN": "标签背景色" }, "default": "#333333" },

    { "type": "header", "content": { "en-US": "Spacing", "zh-CN": "间距留白" } },
    { "type": "spacing", "id": "spacing", "label": { "en-US": "Spacing", "zh-CN": "间距留白" },
      "pc":     { "top": "40", "right": "", "bottom": "40", "left": "" },
      "mobile": { "top": "20", "right": "", "bottom": "20", "left": "" },
      "default": {
        "pc":     { "top": "40", "right": "", "bottom": "40", "left": "" },
        "mobile": { "top": "20", "right": "", "bottom": "20", "left": "" }
      }
    }
  ],

  "blocks": [
    {
      "type": "tag",
      "name": { "en-US": "Tag", "zh-CN": "标签" },
      "settings": [
        { "type": "text", "id": "tag_name", "label": { "en-US": "Tag name", "zh-CN": "标签名" }, "default": "Tag" },
        { "type": "url",  "id": "link",     "label": { "en-US": "Link (optional)", "zh-CN": "链接（可选）" } }
      ]
    }
  ],

  "presets": [
    {
      "name": "tag_list",
      "cname": { "en-US": "Tag list (ElecHub)", "zh-CN": "标签列表（ElecHub）" },
      "category": { "en-US": "Page", "zh-CN": "页面" },
      "ccategory": { "en-US": "Page", "zh-CN": "页面" },
      "display": true,
      "blocks": [
        { "type": "tag", "settings": { "tag_name": "Tag" } },
        { "type": "tag", "settings": { "tag_name": "Tag" } },
        { "type": "tag", "settings": { "tag_name": "Tag" } },
        { "type": "tag", "settings": { "tag_name": "Tag" } }
      ]
    }
  ]
}
{% endschema %}
