{% comment %}
File: sections/video-with-text.liquid
Theme: Shoplaza · ElecHub
Notes:
- 复用 ElecHub 的间距体系：{% include 'card_spacing_css' %} + settings.spacing + page-container/container 结构
- 支持 MP4 / YouTube / Vimeo、左右布局、移动/桌面对齐、封面图、按钮、颜色
{% endcomment %}

{% include 'card_spacing_css' %}

{%- assign mobile_align  = section.settings.mobile_text_alignment -%}
{%- assign desktop_align = section.settings.desktop_text_alignment -%}
{%- assign bg            = section.settings.background -%}
{%- assign txt           = section.settings.text_color -%}

<style>
  /* 仅做布局与间距适配，不覆盖主题字体字号 */
  [data-section-id="{{ section.id }}"] .vwt__wrap{
    display:flex; gap:24px; align-items:center;
    background: {{ bg }};
    color: {{ txt }};
  }
  [data-section-id="{{ section.id }}"] .vwt__wrap.--reverse{ flex-direction: row-reverse; }

  [data-section-id="{{ section.id }}"] .vwt__media{ flex:1 1 55%; }
  [data-section-id="{{ section.id }}"] .vwt__content{ flex:1 1 45%; text-align: {{ mobile_align }}; }

  @media (min-width: 960px){
    [data-section-id="{{ section.id }}"] .vwt__content{ text-align: {{ desktop_align }}; }
  }

  /* 媒体容器（与 ElecHub 圆角/阴影风格兼容） */
  [data-section-id="{{ section.id }}"] .vwt__poster{
    position:relative; width:100%; aspect-ratio:16/9;
    background:#f5f5f5; overflow:hidden; border-radius:8px;
    display:flex; align-items:center; justify-content:center;
  }
  [data-section-id="{{ section.id }}"] .vwt__poster img{ width:100%; height:100%; object-fit:cover; display:block; }
  [data-section-id="{{ section.id }}"] .vwt__poster iframe,
  [data-section-id="{{ section.id }}"] .vwt__poster video{
    width:100%; height:100%; border:0; display:block; border-radius:8px; background:#000;
  }

  /* 文案仅做外边距，字号走主题 */
  [data-section-id="{{ section.id }}"] .vwt__sub{ margin:0 0 8px; opacity:.8; }
  [data-section-id="{{ section.id }}"] .vwt__title{ margin:0 0 12px; }
  [data-section-id="{{ section.id }}"] .vwt__text{ margin:12px 0 16px; line-height:1.7; }

  /* 按钮沿用主题风格：颜色来自设置，交互轻微 */
  [data-section-id="{{ section.id }}"] .vwt__btn{
    display:inline-flex; align-items:center; justify-content:center;
    padding:10px 18px; border-radius:999px; text-decoration:none; font-weight:600;
    background: {{ section.settings.button_background }}; color: {{ section.settings.button_text_color }};
    transition: transform .15s ease, box-shadow .15s ease, opacity .2s ease;
  }
  [data-section-id="{{ section.id }}"] .vwt__btn:hover{ transform:translateY(-1px); box-shadow:0 4px 10px rgba(0,0,0,.12); opacity:.95; }

  /* 移动端上下堆叠 */
  @media (max-width: 959.98px){
    [data-section-id="{{ section.id }}"] .vwt__wrap{ flex-direction:column; }
  }
</style>

<div class="page-container container lg:container" data-section-id="{{ section.id }}">
  <div class="vwt">
    {%- if section.settings.heading != blank -%}
      <h4 class="m-0 title-font type-heading-font-family font-normal leading-1.2 overflow-hidden">
        {{ section.settings.heading | escape }}
      </h4>
    {%- endif -%}

    <!-- 与 collection_list 保持：内容区顶边距移动端 pt-2、PC 端 lg:pt-1 -->
    <div class="vwt__wrap pt-2 lg:pt-1 {% if section.settings.video_position == 'right' %}--reverse{% endif %}">

      <!-- 媒体侧 -->
      <div class="vwt__media">
        {%- assign mp4 = section.settings.mp4_url -%}
        {%- assign url = section.settings.video_url | downcase -%}
        {%- assign is_yt = url contains 'youtube.com' or url contains 'youtu.be' -%}
        {%- assign is_vm = url contains 'vimeo.com' -%}

        {%- if mp4 != blank -%}
          <div class="vwt__poster" style="{% if section.settings.poster != blank %}background:none{% endif %}">
            {%- if section.settings.poster != blank -%}
              <img src="{{ section.settings.poster | image_url: width: 1600 }}" alt="{{ section.settings.title | escape }}">
            {%- endif -%}
            <video
              {% if section.settings.autoplay %}autoplay muted loop playsinline{% endif %}
              {% if section.settings.show_video_controls %}controls{% endif %}
              poster="{% if section.settings.poster != blank %}{{ section.settings.poster | image_url: width: 1600 }}{% endif %}">
              <source src="{{ mp4 }}" type="video/mp4">
            </video>
          </div>

        {%- elsif is_yt -%}
          <div class="vwt__poster">
            <iframe
              title="{{ section.settings.title | escape }}"
              src="https://www.youtube.com/embed/{% if section.settings.video_url contains 'watch?v=' %}{{ section.settings.video_url | split: 'watch?v=' | last | split: '&' | first }}{% else %}{{ section.settings.video_url | split: '/' | last }}{% endif %}?playsinline=1{% if section.settings.autoplay %}&autoplay=1&mute=1&loop=1&playlist={% if section.settings.video_url contains 'watch?v=' %}{{ section.settings.video_url | split: 'watch?v=' | last | split: '&' | first }}{% else %}{{ section.settings.video_url | split: '/' | last }}{% endif %}&controls=0{% endif %}&rel=0&modestbranding=1"
              allow="autoplay; encrypted-media" allowfullscreen></iframe>
          </div>

        {%- elsif is_vm -%}
          <div class="vwt__poster">
            <iframe
              title="{{ section.settings.title | escape }}"
              src="https://player.vimeo.com/video/{{ section.settings.video_url | split: '/' | last }}{% if section.settings.autoplay %}?autoplay=1&muted=1&loop=1&background=1{% endif %}"
              allow="autoplay; encrypted-media" allowfullscreen></iframe>
          </div>

        {%- else -%}
          <div class="vwt__poster">
            {% if section.settings.poster != blank %}
              <img src="{{ section.settings.poster | image_url: width: 1600 }}" alt="poster">
            {% else %}
              {{ 'image' | placeholder_svg_tag }}
            {% endif %}
          </div>
        {%- endif -%}
      </div>

      <!-- 文案侧 -->
      <div class="vwt__content">
        {% if section.settings.subheading != blank %}
          <div class="vwt__sub title-font type-heading-font-family">{{ section.settings.subheading | escape }}</div>
        {% endif %}

        {% if section.settings.title != blank %}
          <h2 class="vwt__title title-font type-heading-font-family">{{ section.settings.title | escape }}</h2>
        {% endif %}

        {% if section.settings.content != blank %}
          <div class="vwt__text">{{ section.settings.content }}</div>
        {% endif %}

        {% if section.settings.button_text != blank and section.settings.button_link != blank %}
          <a class="vwt__btn" href="{{ section.settings.button_link }}">{{ section.settings.button_text }}</a>
        {% endif %}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "video-with-text",
  "templates": ["index", "collection", "product", "page"],
  "settings": [
    { "type": "text", "id": "heading", "label": { "en-US": "Section heading", "zh-CN": "区块标题" }, "default": "" },

    { "type": "select", "id": "video_position", "label": { "en-US": "Desktop video position", "zh-CN": "桌面端视频位置" },
      "options": [
        { "value": "left",  "label": { "en-US": "Left",  "zh-CN": "居左" } },
        { "value": "right", "label": { "en-US": "Right", "zh-CN": "居右" } }
      ],
      "default": "left"
    },

    { "type": "select", "id": "desktop_text_alignment", "label": { "en-US": "Desktop text alignment", "zh-CN": "桌面端文字对齐" },
      "options": [
        { "value": "left",   "label": { "en-US": "Left",   "zh-CN": "左对齐" } },
        { "value": "center", "label": { "en-US": "Center", "zh-CN": "居中" } },
        { "value": "right",  "label": { "en-US": "Right",  "zh-CN": "右对齐" } }
      ],
      "default": "center"
    },
    { "type": "select", "id": "mobile_text_alignment", "label": { "en-US": "Mobile text alignment", "zh-CN": "移动端文字对齐" },
      "options": [
        { "value": "left",   "label": { "en-US": "Left",   "zh-CN": "左对齐" } },
        { "value": "center", "label": { "en-US": "Center", "zh-CN": "居中" } },
        { "value": "right",  "label": { "en-US": "Right",  "zh-CN": "右对齐" } }
      ],
      "default": "center"
    },

    { "type": "header", "content": { "en-US": "Media", "zh-CN": "媒体" } },
    { "type": "image_picker", "id": "poster", "label": { "en-US": "Cover image (poster)", "zh-CN": "封面图（可选）" } },
    { "type": "text", "id": "mp4_url", "label": { "en-US": "MP4 video URL", "zh-CN": "MP4 视频链接" }, "info": { "en-US": "Paste an https .mp4 URL", "zh-CN": "粘贴可访问的 https MP4 链接" } },
    { "type": "text", "id": "video_url", "label": { "en-US": "YouTube/Vimeo URL", "zh-CN": "YouTube/Vimeo 链接" }, "default": "" },
    { "type": "checkbox", "id": "autoplay", "label": { "en-US": "Autoplay (muted)", "zh-CN": "自动播放（静音）" }, "default": true },
    { "type": "checkbox", "id": "show_video_controls", "label": { "en-US": "Show controls (MP4)", "zh-CN": "显示控件（MP4）" }, "default": true },

    { "type": "header", "content": { "en-US": "Content", "zh-CN": "文案" } },
    { "type": "text", "id": "subheading", "label": { "en-US": "Subheading", "zh-CN": "副标题" }, "default": "Subheading" },
    { "type": "text", "id": "title", "label": { "en-US": "Heading", "zh-CN": "主标题" }, "default": "Video with text" },
    { "type": "richtext", "id": "content", "label": { "en-US": "Content", "zh-CN": "正文" }, "default": "<p>Use video with text to tell your brand story. Choose media and copy that match your style.</p>" },
    { "type": "text", "id": "button_text", "label": { "en-US": "Button text", "zh-CN": "按钮文案" } },
    { "type": "url",  "id": "button_link", "label": { "en-US": "Button link", "zh-CN": "按钮链接" } },

    { "type": "header", "content": { "en-US": "Spacing", "zh-CN": "间距留白" } },
    { "type": "spacing", "id": "spacing", "label": { "en-US": "Spacing", "zh-CN": "间距留白" },
      "pc": { "top": "40", "right": "", "bottom": "40", "left": "" },
      "mobile": { "top": "20", "right": "", "bottom": "20", "left": "" },
      "default": {
        "pc": { "top": "40", "right": "", "bottom": "40", "left": "" },
        "mobile": { "top": "20", "right": "", "bottom": "20", "left": "" }
      }
    }
  ],
  "presets": [
    {
      "name": "video-with-text",
      "cname": { "en-US": "Video with text (ElecHub)", "zh-CN": "视频+文字（ElecHub）" },
      "category": { "en-US": "Page", "zh-CN": "页面" },
      "ccategory": { "en-US": "Page", "zh-CN": "页面" },
      "display": true
    }
  ]
}
{% endschema %}
